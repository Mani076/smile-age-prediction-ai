# Application Settings
APP_NAME=AI Image Analysis Tool
APP_VERSION=1.0.0
DEBUG=True

# Security
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_image_analysis

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# File Upload
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=.jpg,.jpeg,.png,.webp

# ML Models
MODEL_DIR=ml_models
AGE_MODEL_PATH=ml_models/age_model.h5
SMILE_MODEL_PATH=ml_models/smile_model.h5
EMOTION_MODEL_PATH=ml_models/emotion_model.h5
FACE_CASCADE_PATH=ml_models/haarcascade_frontalface_default.xml

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Logging
LOG_LEVEL=INFO
